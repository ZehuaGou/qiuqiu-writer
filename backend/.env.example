# 应用配置
APP_NAME=WriterAI Backend
APP_VERSION=1.0.0
DEBUG=true

# 服务器配置
HOST=0.0.0.0
PORT=8000

# 跨域配置
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001

# 安全配置
SECRET_KEY=your-super-secret-key-change-in-production-environment
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200
REFRESH_TOKEN_EXPIRE_MINUTES=10080

# PostgreSQL数据库配置
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=writerai

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB配置（ShareDB）
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_USERNAME=
MONGODB_PASSWORD=
MONGODB_DATABASE=writerai_sharedb

# Qdrant向量数据库配置
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=

# AI服务配置
AI_API_BASE_URL=http://localhost:8001
AI_API_TIMEOUT=120
AI_MAX_RETRIES=3

# 文件存储配置
UPLOAD_DIR=uploads
MAX_FILE_SIZE=104857600
ALLOWED_FILE_EXTENSIONS=.txt,.docx,.pdf,.md

# 邮件配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=noreply@writerai.com

# 分页配置
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# 缓存配置
CACHE_TTL=3600

# ShareDB配置
SHAREDB_DOCUMENT_TTL=86400

# 受信任主机配置
ALLOWED_HOSTS=*

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json