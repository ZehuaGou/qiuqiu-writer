# ==========================================
# AI服务配置 - 拆书分析接口
# ==========================================
# 复制此文件为 .env 或 .env.local 并填写实际的配置值

# OpenAI API配置
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_API_BASE=https://api.openai.com/v1

# MemReader配置（用于记忆读取和处理）
MEMRADER_API_KEY=your_openai_api_key_here
MEMRADER_API_BASE=https://api.openai.com/v1
MEMRADER_MODEL=gpt-4o-mini
MEMRADER_MAX_TOKENS=8000

# 默认AI模型设置
DEFAULT_AI_MODEL=gpt-3.5-turbo

# API服务配置
API_HOST=0.0.0.0
API_PORT=8001

# MemOS配置（如果需要）
MOS_USER_ID=default_user
MOS_SESSION_ID=default_session
MOS_TOP_K=5
MOS_CHAT_MODEL_PROVIDER=openai
MOS_CHAT_MODEL=gpt-3.5-turbo
MOS_CHAT_TEMPERATURE=0.7

# 日志级别
LOG_LEVEL=INFO

# ==========================================
# 使用说明：
# ==========================================
# 1. 获取OpenAI API密钥：https://platform.openai.com/api-keys
# 2. 如果使用其他OpenAI兼容的API（如Azure、本地部署的模型），
#    修改OPENAI_API_BASE为对应的API端点
# 3. 可选的AI模型：
#    - gpt-3.5-turbo (推荐，性价比高)
#    - gpt-4 (更强大但更贵)
#    - gpt-4-turbo-preview
#    - gpt-4o
#    - claude-3-sonnet (需要配置对应的API)
#    - claude-3-opus

