# ==========================================
# AI服务配置 - 拆书分析接口
# ==========================================
# 复制此文件为 .env 或 .env.local 并填写实际的配置值

# OpenAI API配置
OPENAI_API_KEY=sk-5b8dc562ef4647738b008c011bbf4acc
OPENAI_API_BASE=https://api.deepseek.com/v1

# 默认AI模型设置
DEFAULT_AI_MODEL=deepseek-chat

# API服务配置
API_HOST=0.0.0.0
API_PORT=8001

# MemOS配置（如果需要）
MOS_USER_ID=default_user
MOS_SESSION_ID=default_session
MOS_TOP_K=5
MOS_CHAT_MODEL_PROVIDER=openai
MOS_CHAT_MODEL=deepseek-chat
MOS_CHAT_TEMPERATURE=0.7
MOS_USER_MANAGER_BACKEND=postgres
# 记忆开关（关闭 MemOS 记忆检索/写入）
ENABLE_TEXTUAL_MEMORY=false
ENABLE_PREFERENCE_MEMORY=false
ENABLE_ACTIVATION_MEMORY=false
MOS_ENABLE_SCHEDULER=false

# MemReader配置（用于记忆抽取）
MEMRADER_API_KEY=sk-5b8dc562ef4647738b008c011bbf4acc
MEMRADER_API_BASE=https://api.deepseek.com/v1
MEMRADER_MODEL=deepseek-chat

# 日志级别
LOG_LEVEL=INFO

# ==========================================
# Qdrant 向量数据库配置
# ==========================================
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333

# 设为 true 可禁用 Qdrant（聊天等将不连接 Qdrant，不落向量记忆）
DISABLE_QDRANT=true

# Neo4j 图数据库（MemOS 记忆图）
# 设为 true 可禁用 Neo4j（聊天等将不连接 Neo4j，不落图记忆）
DISABLE_NEO4J=true
# ==========================================
# Neo4j 图数据库配置（如果需要）
# ==========================================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678
NEO4J_DB_NAME=neo4j

# ==========================================
# 嵌入向量维度配置
# ==========================================
EMBEDDING_DIMENSION=768
MOS_RERANKER_BACKEND=cosine_local
MOS_EMBEDDER_BACKEND=universal_api

# ==========================================
# MONGODB配置
# ==========================================
MONGODB_HOST=localhost
MONGODB_PORT=27017
MONGODB_DATABASE=writerai_sharedb
# 默认 docker 启动的 mongodb 可能没有认证，如果不匹配可以注释掉下面两行
# MONGODB_USERNAME=writerai
# MONGODB_PASSWORD=kangkang123
MOS_EMBEDDER_BACKEND=sentence_transformer
MOS_EMBEDDER_MODEL=/app/models/nomic-embed-text-v1.5
HF_LOCAL_FILES_ONLY=true

# ==========================================
# PostgreSQL配置
# ==========================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=writerai

# ==========================================
# Redis配置
# ==========================================
REDIS_HOST=localhost
REDIS_PORT=6379
# 如果没有设置密码，可以留空或注释
# REDIS_PASSWORD=
